# Supabase Auth Configuration
# Not required for `npm run dev`; local development uses the no-auth dev mode.
# Required for production, Vercel preview/staging, and auth-backed API routes.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Convex Database + Realtime Configuration
# Local development should point at the shared dev deployment below.
NEXT_PUBLIC_CONVEX_URL=https://shocking-panda-595.convex.cloud
CONVEX_DEPLOYMENT=dev:shocking-panda-595

# Required only in Vercel Production so `npm run build:vercel` deploys Convex before Next builds.
CONVEX_DEPLOY_KEY=your_convex_deploy_key_here

# Convex auth bridge: private key used by /api/convex-token to mint RS256 JWTs.
# Generate/rotate this with an RSA private key; do not commit the real value.
CONVEX_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Google Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
