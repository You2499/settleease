# Supabase Auth Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Convex Database + Realtime Configuration
NEXT_PUBLIC_CONVEX_URL=your_convex_url_here
CONVEX_DEPLOYMENT=your_convex_deployment_here

# Required in Vercel so `npm run build:vercel` deploys Convex before Next builds.
CONVEX_DEPLOY_KEY=your_convex_deploy_key_here

# Convex auth bridge: private key used by /api/convex-token to mint RS256 JWTs.
# Generate/rotate this with an RSA private key; do not commit the real value.
CONVEX_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Google Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
