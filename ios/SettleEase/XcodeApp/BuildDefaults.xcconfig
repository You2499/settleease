// Non-secret defaults for the personal iOS build.
// Create XcodeApp/Secrets.xcconfig from Secrets.xcconfig.example to override these locally.

SETTLEEASE_SUPABASE_URL =
SETTLEEASE_SUPABASE_ANON_KEY =
SETTLEEASE_CONVEX_URL =
SETTLEEASE_WEB_BASE_URL = https:/$()/settleease-navy.vercel.app
SETTLEEASE_OAUTH_REDIRECT_URL = settleease:/$()/auth-callback

#include? "Secrets.xcconfig"
