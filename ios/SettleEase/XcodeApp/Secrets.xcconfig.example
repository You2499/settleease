// Copy to Secrets.xcconfig for personal-device builds.
// The copied file is gitignored.
SETTLEEASE_SUPABASE_URL = https:/$()/YOUR_PROJECT.supabase.co
SETTLEEASE_SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_KEY
SETTLEEASE_CONVEX_URL = https:/$()/YOUR_CONVEX_DEPLOYMENT.convex.cloud
SETTLEEASE_WEB_BASE_URL = https:/$()/settleease-navy.vercel.app
SETTLEEASE_OAUTH_REDIRECT_URL = settleease:/$()/auth-callback
